{
  "name": "codemata",
  "devDependencies": {
    "prettier": "^3.8.1",
    "syncpack": "^14.2.0"
  },
  "packageManager": "pnpm@10.32.1",
  "prettier": {
    "useTabs": false,
    "singleQuote": false,
    "trailingComma": "none",
    "printWidth": 120
  },
  "scripts": {
    "build": "pnpm -r build",
    "format": "prettier -c --write . && syncpack format",
    "pkg:lint": "syncpack fix --specifier-types range",
    "pkg:update": "syncpack update"
  },
  "type": "module"
}
